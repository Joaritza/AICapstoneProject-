# API Keys
GITHUB_TOKEN=github_pat_YOUR_GITHUB_TOKEN_HERE
SPOONACULAR_API_KEY=your_spoonacular_api_key_here
USDA_API_KEY=your_usda_api_key_here

# LLM Configuration (using GitHub Models inference endpoint with GitHub token)
# Endpoint: https://models.github.ai/inference
# Model: openai/gpt-4o (GPT-4o via GitHub Models)
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Application Settings
DEBUG=False
LOG_LEVEL=INFO
CACHE_TYPE=file
CACHE_TTL_HOURS=24

# UI Settings
STREAMLIT_SERVER_PORT=8501
NATURE_THEME=True
